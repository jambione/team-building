""  
"      - name: Install Dependencies"  
"        run: npm ci --ignore-scripts" 
""  
"      - name: Run Linter"  
"        run: npm run lint" 
""  
"        run: npm run lint"  
"        continue-on-error: false" 
""  
"        continue-on-error: false"  
""  
"# Upload lint report artifact" 
"        uses: actions/upload-artifact@v4"  
""  
